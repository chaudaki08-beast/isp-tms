# ─────────────────────────────────────────────────────────────
# ISP Technician Management System — Environment Variables
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres) ──────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string.
# Use the "Connection pooling" (Transaction mode, port 6543) URL for the
# app, and the "Direct connection" (port 5432) URL for migrations.
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:5432/postgres"

# ── Auth.js (NextAuth) ────────────────────────────────────────
# Generate a secret with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# On Vercel this is set automatically; locally use your dev URL.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ── Supabase Storage (photos, selfies, signatures, receipts) ──
# Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
# Service-role key — SERVER ONLY, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Storage bucket name (create it in Supabase → Storage).
SUPABASE_STORAGE_BUCKET="isp-uploads"

# ── Google Maps (live technician tracking) ────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-browser-key"

# ── Firebase Cloud Messaging (push notifications, optional) ───
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""
FIREBASE_SERVER_KEY=""

# ── WhatsApp Business API (future-ready, optional) ────────────
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_ID=""

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="ISP Technician Management"
